{
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)"
    ]
  },
  "models": {
    "default": "sonnet",
    "architect": "opus"
  },
  "autoReview": true,
  "reviewAgent": "code-reviewer"
}
